# Índices de ajuste — con df=0 CFI/TLI = 1 por construcción; reportar cargas
b3_indices <- fitMeasures(b3_afc_fit, c("cfi","tli","rmsea","srmr","chisq","df","pvalue"))
cat("  χ²(", b3_indices["df"], ")=", round(b3_indices["chisq"], 2),
"  — modelo just-identified (df=0, ajuste perfecto por construcción)\n")
cat("  Cargas estandarizadas:\n")
print(standardizedSolution(b3_afc_fit) %>%
filter(op == "=~") %>%
select(lhs, rhs, est.std, se, pvalue))
# Empaquetamos igual que los otros bloques
b3_afc <- list(
fit     = b3_afc_fit,
indices = b3_indices,
passed  = TRUE   # just-identified siempre ajusta perfectamente
)
scores_b3 <- lavPredict(b3_afc$fit)
cat("  Factor scores B3 generados:", nrow(scores_b3), "×", ncol(scores_b3), "\n")
# Guardar state_ord aparte como covariable geográfica (no como factor latente)
state_covar <- df %>%
slice(which(complete.cases(df[, vars_b3_reduced]))) %>%
select(loan_id, state_ord, property_state)
cat("  state_ord conservada como covariable geográfica para clustering.\n")
# =============================================================================
# CONSTRUCCIÓN DEL ESPACIO LATENTE UNIFICADO
# =============================================================================
cat("\n", strrep("=", 70), "\n")
cat("INTEGRACIÓN: Latent_Space = [F_originación | F_comportamiento | F_macro]\n")
cat(strrep("=", 70), "\n")
# Alinear filas (usar loan_id como ancla)
n_full <- nrow(df)
# Reconstruir índices de observaciones válidas para cada bloque
idx_b1 <- which(complete.cases(df[, vars_b1]))
idx_b2 <- which(complete.cases(df[, vars_b2]))
idx_b3 <- which(complete.cases(df[, vars_b3]))
# Filas comunes a los tres bloques
idx_common <- Reduce(intersect, list(idx_b1, idx_b2, idx_b3))
cat("  Observaciones con los 3 bloques completos:", length(idx_common), "\n")
latent_space <- bind_cols(
df[idx_common, "loan_id"],
as_tibble(scores_b1[match(idx_common, idx_b1), , drop = FALSE]) %>%
rename_with(~ paste0("orig_", .)),
as_tibble(scores_b2[match(idx_common, idx_b2), , drop = FALSE]) %>%
rename_with(~ paste0("comp_", .)),
as_tibble(scores_b3[match(idx_common, idx_b3), , drop = FALSE]) %>%
rename_with(~ paste0("macro_", .))
) %>%
# Añadir state_ord como covariable geográfica (no es factor latente)
left_join(state_covar %>% select(loan_id, state_ord, property_state),
by = "loan_id")
cat("  Dimensiones del espacio latente:", nrow(latent_space), "×", ncol(latent_space), "\n")
print(head(latent_space, 3))
# Exportar para clustering / deep learning
OUTPUT_DIR <- dirname(DATA_PATH)
write_csv(latent_space, file.path(OUTPUT_DIR, "latent_space_unified.csv"))
cat("\n✔ latent_space_unified.csv guardado en:", OUTPUT_DIR, "\n")
# =============================================================================
# VISUALIZACIONES RESUMEN
# =============================================================================
# 1. Heatmaps de matrices de correlación por bloque
pdf(file.path(OUTPUT_DIR, "correlation_heatmaps.pdf"), width = 12, height = 10)
par(mfrow = c(1, 3))
corrplot(b1_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B1: Originación", mar = c(0,0,2,0))
corrplot(b2_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B2: Comportamiento", mar = c(0,0,2,0))
corrplot(b3_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B3: Contextual", mar = c(0,0,2,0))
dev.off()
# 2. Diagramas de sendero AFC
pdf(file.path(OUTPUT_DIR, "path_diagrams_AFC.pdf"), width = 14, height = 10)
semPaths(b1_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 1 — Originación")
semPaths(b2_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 2 — Comportamiento")
semPaths(b3_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 3 — Contextual")
dev.off()
# 3. Distribución de factor scores del espacio latente
score_cols <- names(latent_space)[-1]
p_list <- lapply(score_cols, function(col) {
ggplot(latent_space, aes_string(x = col)) +
geom_histogram(bins = 30, fill = "#2E86C1", color = "white", alpha = 0.8) +
theme_minimal() +
labs(title = col, x = NULL, y = "n")
})
pdf(file.path(OUTPUT_DIR, "latent_score_distributions.pdf"),
width = 14, height = ceiling(length(score_cols) / 3) * 3)
do.call(grid.arrange, c(p_list, ncol = 3))
cat("B1 Originación\n")
print(b1_afc$indices)
cat("\nB2 Comportamiento\n")
print(b2_afc$indices)
cat("\nB3 Contextual\n")
print(b3_afc$indices)
# =============================================================================
# PROYECTO: Modelado Latente Multivista — Portafolios Hipotecarios
# FASE II: Análisis Factorial Exploratorio (AFE) y Confirmatorio (AFC)
# Bloques: Originación | Comportamiento | Contextual
# =============================================================================
# ── 0. DEPENDENCIAS ──────────────────────────────────────────────────────────
required_packages <- c(
"tidyverse",   # manipulación de datos
"psych",       # AFE, KMO, Bartlett, fa.parallel
"polycor",     # matrices policóricas / poliseriales
"lavaan",      # AFC con estimador MLR
"semPlot",     # visualización de modelos SEM
"GPArotation", # rotaciones (oblimin)
"parameters",  # extracción ordenada de parámetros
"corrplot",    # heatmaps de correlación
"ggplot2",
"gridExtra"
)
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) install.packages(pkg)
library(pkg, character.only = TRUE)
}
# ── 1. CARGA DE DATOS ─────────────────────────────────────────────────────────
DATA_PATH <- "C:/Users/isape/OneDrive/Escritorio/ANALITICA/Proyecto1/punto3/data/gold/subset_a/part-00000-5946d355-f9d8-45c1-be26-998f18db765b-c000.csv"
df_raw <- read_csv(DATA_PATH, show_col_types = FALSE)
cat("✔ Datos cargados:", nrow(df_raw), "filas ×", ncol(df_raw), "columnas\n")
# ── 2. PREPARACIÓN GENERAL ────────────────────────────────────────────────────
# Recodificación de binarias / ordinales
df <- df_raw %>%
mutate(
first_time_buyer        = ifelse(first_time_buyer == "Y", 1L, 0L),
has_coborrower          = as.integer(has_coborrower),
high_balance_loan_indicator = ifelse(high_balance_loan_indicator == "Y", 1L, 0L),
ever_modified           = as.integer(ever_modified),
had_forbearance         = as.integer(had_forbearance),
# Ordinales para canal, propósito, tipo propiedad, ocupación
channel_ord    = as.integer(factor(channel,
levels = c("R","B","C","T","W","N","O"))),
loan_purpose_ord = as.integer(factor(loan_purpose,
levels = c("P","C","N","R","U"))),
property_type_ord = as.integer(factor(property_type,
levels = c("SF","CO","MH","PU","CP","LH","UT"))),
occupancy_ord  = as.integer(factor(occupancy_status,
levels = c("P","S","I","U"))),
# Contextual
orig_year_std  = as.numeric(scale(origination_year)),
acq_q_num      = as.integer(substr(acquisition_quarter, 6, 6)),  # Q1..Q4
vintage_ord    = as.integer(factor(vintage_bin,
levels = c("Pre-Crisis","Stable","Post-Crisis",
"COVID-era","Recent"))),
state_ord      = as.integer(factor(property_state))
)
# ── HELPER FUNCTIONS ──────────────────────────────────────────────────────────
#' Construye la matriz de correlaciones apropiada para datos mixtos
#' y devuelve la matriz + diagnóstico de factorabilidad
build_cor_matrix <- function(data, vars, data_types = NULL) {
sub <- data %>% select(all_of(vars)) %>% drop_na()
cat("  → N válido:", nrow(sub), "\n")
# Detectar tipo si no se especifica
if (is.null(data_types)) {
data_types <- sapply(sub, function(x) {
if (length(unique(x)) <= 2) "binary"
else if (length(unique(x)) <= 7) "ordinal"
else "continuous"
})
}
# Matriz policórica / poliserial mixta
tryCatch({
het_cor <- hetcor(sub, ML = FALSE, std.err = FALSE)$correlations
het_cor <- as.matrix(het_cor)
rownames(het_cor) <- colnames(het_cor) <- vars
}, error = function(e) {
message("  ⚠ hetcor falló, usando cor de Pearson como respaldo: ", e$message)
het_cor <<- cor(sub, use = "pairwise.complete.obs")
})
list(cor_mat = het_cor, n = nrow(sub), data_clean = sub)
}
#' Diagnóstico de factorabilidad: KMO + Bartlett
factorability_test <- function(cor_mat, n) {
kmo_res  <- KMO(cor_mat)
bart_res <- cortest.bartlett(cor_mat, n = n)
cat("  KMO overall:", round(kmo_res$MSA, 3), "\n")
cat("  Bartlett χ²:", round(bart_res$chisq, 2),
"  df:", bart_res$df,
"  p:", format.pval(bart_res$p.value, digits = 3), "\n")
if (kmo_res$MSA < 0.50) {
warning("  ⚠ KMO < 0.50 — revisar especificación del bloque")
} else if (kmo_res$MSA < 0.60) {
message("  ⚠ KMO entre 0.50 y 0.60 — factorabilidad marginal")
} else {
cat("  ✔ KMO ≥ 0.60 — factorabilidad aceptable\n")
}
invisible(list(kmo = kmo_res, bartlett = bart_res))
}
#' AFE: Análisis Paralelo + MAP → determina nFactors → fa() ML/oblimin
run_afe <- function(cor_mat, n, block_name, nfact_override = NULL) {
cat("\n── AFE:", block_name, "──\n")
p <- ncol(cor_mat)
# Número de factores
if (is.null(nfact_override)) {
ap <- fa.parallel(cor_mat, n.obs = n, fa = "fa", fm = "ml",
main = paste("Scree / Análisis Paralelo —", block_name))
nf_parallel <- ap$nfact
vss_res     <- vss(cor_mat, n.obs = n, rotate = "oblimin", fm = "ml", plot = FALSE)
nf_map      <- which.min(vss_res$map)
cat("  Factores sugeridos — Paralelo:", nf_parallel, "| MAP:", nf_map, "\n")
nf <- max(nf_parallel, nf_map, 1)
} else {
nf <- nfact_override
cat("  Factores forzados:", nf, "\n")
}
# Verificar grados de libertad: df = p*(p-1)/2 - p*nf + nf*(nf-1)/2
# Si df <= 0 el modelo está saturado → reducir a 1 factor
df_model <- p * (p - 1) / 2 - p * nf + nf * (nf - 1) / 2
if (df_model <= 0) {
cat("  ⚠ Modelo saturado con", nf, "factores (df =", df_model,
") — reduciendo a 1 factor\n")
nf <- 1
}
# AFE
afe_res <- fa(cor_mat, nfactors = nf, n.obs = n,
rotate = if (nf == 1) "none" else "oblimin",
fm     = "ml",
cor    = "cor")
# Diagnóstico de comunalidades y cargas cruzadas
comm       <- afe_res$communality
low_comm   <- names(comm[comm < 0.30])
loadings_m <- as.matrix(unclass(afe_res$loadings))
cross_load <- if (nf > 1) apply(loadings_m, 1, function(x) sum(abs(x) > 0.30) > 1) else rep(FALSE, p)
cat("  Comunalidades < 0.30:",
if (length(low_comm) == 0) "ninguna" else paste(low_comm, collapse = ", "), "\n")
cat("  Cargas cruzadas severas:",
if (sum(cross_load) == 0) "ninguna" else paste(names(cross_load[cross_load]), collapse = ", "), "\n")
print(afe_res$loadings, cutoff = 0.30, sort = TRUE)
# RMSEA y TLI: pueden ser NULL, NA o vector vacío si df=0 → extraer con seguridad
safe_scalar <- function(x) {
val <- tryCatch(as.numeric(x), error = function(e) NA_real_)
if (length(val) == 0) NA_real_ else val[1]
}
rmsea_val <- safe_scalar(afe_res$RMSEA["RMSEA"])
tli_val   <- safe_scalar(afe_res$TLI)
cat("  RMSEA AFE:", if (is.na(rmsea_val)) "N/A (modelo saturado)" else round(rmsea_val, 4),
"  TLI:",       if (is.na(tli_val))   "N/A" else round(tli_val, 4), "\n")
invisible(list(model    = afe_res,
nfactors = nf,
low_comm = low_comm,
cross_load = names(cross_load[cross_load])))
}
#' AFC con lavaan MLR — evaluación de ajuste
run_afc <- function(model_syntax, data_clean, block_name) {
cat("\n── AFC:", block_name, "──\n")
fit <- sem(model_syntax, data = data_clean,
estimator  = "MLR",
std.lv     = TRUE,
missing    = "fiml")
idx <- fitMeasures(fit, c("cfi","tli","rmsea","srmr","chisq","df","pvalue"))
cat("  CFI:",   round(idx["cfi"],   3), " (≥0.90)\n")
cat("  TLI:",   round(idx["tli"],   3), " (≥0.90)\n")
cat("  RMSEA:", round(idx["rmsea"], 4), " (<0.08)\n")
cat("  SRMR:",  round(idx["srmr"],  4), " (<0.08)\n")
cat("  χ²(",   idx["df"], ")=", round(idx["chisq"],2),
"  p=", format.pval(idx["pvalue"], digits=3), "\n")
passed <- idx["cfi"] >= 0.90 & idx["tli"] >= 0.90 &
idx["rmsea"] < 0.08 & idx["srmr"] < 0.08
cat("  Ajuste global:", if (passed) "✔ ACEPTABLE" else "✗ REVISAR", "\n")
invisible(list(fit = fit, indices = idx, passed = passed))
}
# =============================================================================
# BLOQUE 1: ORIGINACIÓN (t0)
# =============================================================================
cat("\n", strrep("=", 70), "\n")
cat("BLOQUE 1 — DOMINIO DE ORIGINACIÓN\n")
cat(strrep("=", 70), "\n")
vars_b1_num <- c("borrower_credit_score","dti","orig_ltv","orig_cltv",
"mi_percentage","orig_interest_rate","orig_upb",
"orig_loan_term","num_borrowers")
vars_b1_cat <- c("first_time_buyer","has_coborrower","occupancy_ord",
"loan_purpose_ord","property_type_ord","channel_ord",
"high_balance_loan_indicator")
vars_b1 <- c(vars_b1_num, vars_b1_cat)
# Verificar que las columnas existen
vars_b1 <- intersect(vars_b1, names(df))
cat("Variables disponibles B1:", length(vars_b1), "\n")
b1_cor  <- build_cor_matrix(df, vars_b1)
b1_fact <- factorability_test(b1_cor$cor_mat, b1_cor$n)
# AFE Bloque 1
b1_afe  <- run_afe(b1_cor$cor_mat, b1_cor$n, "Originación")
# ── AFC Bloque 1 ──
# Estructura teórica basada en AFE (ajustar según cargas obtenidas)
# Los factores representan: F1=Capacidad crediticia, F2=Apalancamiento,
# F3=Exposición financiera, F4=Perfil contractual
b1_data <- df %>% select(all_of(vars_b1)) %>% drop_na()
afc_b1_model <- '
# F1: Capacidad crediticia del prestatario
F_crediticia =~ borrower_credit_score + dti + num_borrowers + first_time_buyer + has_coborrower
# F2: Nivel de apalancamiento
F_apalancamiento =~ orig_ltv + orig_cltv + mi_percentage
# F3: Exposición financiera
F_exposicion =~ orig_upb + orig_interest_rate + high_balance_loan_indicator
# F4: Perfil contractual
F_contractual =~ orig_loan_term + loan_purpose_ord + channel_ord + property_type_ord + occupancy_ord
'
b1_afc <- run_afc(afc_b1_model, b1_data, "Originación")
# Factor scores Bloque 1
scores_b1 <- lavPredict(b1_afc$fit)
cat("  Factor scores B1 generados:", nrow(scores_b1), "× ", ncol(scores_b1), "\n")
# =============================================================================
# BLOQUE 2 — COMPORTAMIENTO (ÍNDICE COMPUESTO DEFINITIVO)
# =============================================================================
cat("\n", strrep("=", 70), "\n")
cat("BLOQUE 2 — DOMINIO DE COMPORTAMIENTO (ÍNDICE OBSERVABLE)\n")
cat(strrep("=", 70), "\n")
# -----------------------------------------------------------------------------
# 1. Selección de variables coherentes con deterioro real
# -----------------------------------------------------------------------------
vars_b2 <- c(
"months_delinquent_30plus",
"months_delinquent_90plus",
"max_delinquency_status",
"ph_max_delinquency_24"
)
vars_b2 <- intersect(vars_b2, names(df))
cat("Variables utilizadas B2:", length(vars_b2), "\n")
# -----------------------------------------------------------------------------
# 2. Construcción dataset limpio
# -----------------------------------------------------------------------------
b2_data <- df %>%
select(all_of(vars_b2)) %>%
drop_na()
cat("Observaciones válidas B2:", nrow(b2_data), "\n")
# -----------------------------------------------------------------------------
# 3. Verificación de colinealidad
# -----------------------------------------------------------------------------
cor_b2 <- cor(b2_data)
print(round(cor_b2, 3))
# -----------------------------------------------------------------------------
# 4. Estandarización (escala comparable)
# -----------------------------------------------------------------------------
b2_scaled <- scale(b2_data)
# -----------------------------------------------------------------------------
# 5. Consistencia interna (opcional pero recomendable)
# -----------------------------------------------------------------------------
library(psych)
alpha_b2 <- psych::alpha(b2_scaled)
cat("\nAlpha de Cronbach B2:", round(alpha_b2$total$raw_alpha, 3), "\n")
# -----------------------------------------------------------------------------
# 6. Construcción del Índice de Deterioro
# -----------------------------------------------------------------------------
indice_deterioro <- rowMeans(b2_scaled)
df$indice_comportamiento <- NA
df$indice_comportamiento[complete.cases(df[, vars_b2])] <- indice_deterioro
cat("\nÍndice de Comportamiento generado.\n")
# -----------------------------------------------------------------------------
# 7. Normalización opcional 0–1 (interpretabilidad ejecutiva)
# -----------------------------------------------------------------------------
min_val <- min(indice_deterioro)
max_val <- max(indice_deterioro)
df$indice_comportamiento_01 <- NA
df$indice_comportamiento_01[complete.cases(df[, vars_b2])] <-
(indice_deterioro - min_val) / (max_val - min_val)
cat("Índice normalizado 0–1 generado.\n")
# -----------------------------------------------------------------------------
# 8. Resumen descriptivo final
# -----------------------------------------------------------------------------
summary(df$indice_comportamiento)
summary(df$indice_comportamiento_01)
# =============================================================================
# BLOQUE 3: CONTEXTUAL (Macro / Cohorte)
# =============================================================================
cat("\n", strrep("=", 70), "\n")
cat("BLOQUE 3 — DOMINIO CONTEXTUAL\n")
cat(strrep("=", 70), "\n")
# ── Nota metodológica ──
# El Bloque 3 tiene solo 4 variables y KMO marginal (0.50-0.60).
# acq_q_num y state_ord muestran comunalidades < 0.30 con cualquier
# especificación de 2 factores → modelo saturado con df = 0.
# Decisión: usar SOLO las 2 variables con comunalidades altas
# (orig_year_std y vintage_ord) más 1 variable adicional para identificación.
# Se retiene acq_q_num como tercer indicador para evitar modelo just-identified
# con lavaan (mín. 3 indicadores por factor en modelo de 1 factor).
# state_ord se descarta por baja comunalidad (captura ruido geográfico puro).
vars_b3_full    <- c("orig_year_std", "acq_q_num", "vintage_ord", "state_ord")
vars_b3_reduced <- c("orig_year_std", "vintage_ord", "acq_q_num")   # estado excluido
vars_b3_full    <- intersect(vars_b3_full,    names(df))
vars_b3_reduced <- intersect(vars_b3_reduced, names(df))
cat("Variables totales B3:", length(vars_b3_full),
"| Retenidas para AFE/AFC:", length(vars_b3_reduced), "\n")
cat("  Excluida: state_ord (comunalidad < 0.30 en diagnóstico previo)\n")
# Correlaciones y factorabilidad sobre set reducido
b3_cor  <- build_cor_matrix(df, vars_b3_reduced)
b3_fact <- factorability_test(b3_cor$cor_mat, b3_cor$n)
# AFE con 1 solo factor (3 vars → df = 0 con 1F, pero es la única opción viable)
# df = p*(p-1)/2 - p*nf + nf*(nf-1)/2  = 3*2/2 - 3*1 + 0 = 0  → saturado
# Aunque saturado, la carga factorial es interpretable y necesaria para AFC.
cat("\n  ⚠ Con p=3 y nf=1 el AFE tiene df=0 (modelo saturado).\n")
cat("  Se procede como análisis de factorabilidad / carga para guiar el AFC.\n")
b3_afe <- run_afe(b3_cor$cor_mat, b3_cor$n, "Contextual", nfact_override = 1)
# ── AFC Bloque 3 ──
# Con 3 indicadores y 1 factor latente: modelo just-identified (df=0).
# lavaan lo estima pero no produce índices de ajuste significativos.
# Se fija la escala del factor con std.lv = TRUE.
b3_data <- df %>% select(all_of(vars_b3_reduced)) %>% drop_na()
afc_b3_model <- '
# F_cohorte: captura la dimensión temporal / macroeconómica de la cohorte
# orig_year_std y vintage_ord son casi transformaciones lineales del mismo constructo
# acq_q_num aporta variación intra-año (estacionalidad de originación)
F_cohorte =~ orig_year_std + vintage_ord + acq_q_num
'
cat("\n── AFC: Contextual (1 factor, modelo just-identified) ──\n")
b3_afc_fit <- sem(afc_b3_model,
data      = b3_data,
estimator = "MLR",
std.lv    = TRUE,
missing   = "fiml")
# Índices de ajuste — con df=0 CFI/TLI = 1 por construcción; reportar cargas
b3_indices <- fitMeasures(b3_afc_fit, c("cfi","tli","rmsea","srmr","chisq","df","pvalue"))
cat("  χ²(", b3_indices["df"], ")=", round(b3_indices["chisq"], 2),
"  — modelo just-identified (df=0, ajuste perfecto por construcción)\n")
cat("  Cargas estandarizadas:\n")
print(standardizedSolution(b3_afc_fit) %>%
filter(op == "=~") %>%
select(lhs, rhs, est.std, se, pvalue))
# Empaquetamos igual que los otros bloques
b3_afc <- list(
fit     = b3_afc_fit,
indices = b3_indices,
passed  = TRUE   # just-identified siempre ajusta perfectamente
)
scores_b3 <- lavPredict(b3_afc$fit)
cat("  Factor scores B3 generados:", nrow(scores_b3), "×", ncol(scores_b3), "\n")
# Guardar state_ord aparte como covariable geográfica (no como factor latente)
state_covar <- df %>%
slice(which(complete.cases(df[, vars_b3_reduced]))) %>%
select(loan_id, state_ord, property_state)
cat("  state_ord conservada como covariable geográfica para clustering.\n")
# =============================================================================
# CONSTRUCCIÓN DEL ESPACIO LATENTE UNIFICADO
# =============================================================================
cat("\n", strrep("=", 70), "\n")
cat("INTEGRACIÓN: Latent_Space = [F_originación | F_comportamiento | F_macro]\n")
cat(strrep("=", 70), "\n")
# Alinear filas (usar loan_id como ancla)
n_full <- nrow(df)
# Reconstruir índices de observaciones válidas para cada bloque
idx_b1 <- which(complete.cases(df[, vars_b1]))
idx_b2 <- which(complete.cases(df[, vars_b2]))
idx_b3 <- which(complete.cases(df[, vars_b3]))
# Filas comunes a los tres bloques
idx_common <- Reduce(intersect, list(idx_b1, idx_b2, idx_b3))
cat("  Observaciones con los 3 bloques completos:", length(idx_common), "\n")
latent_space <- bind_cols(
df[idx_common, "loan_id"],
as_tibble(scores_b1[match(idx_common, idx_b1), , drop = FALSE]) %>%
rename_with(~ paste0("orig_", .)),
as_tibble(scores_b2[match(idx_common, idx_b2), , drop = FALSE]) %>%
rename_with(~ paste0("comp_", .)),
as_tibble(scores_b3[match(idx_common, idx_b3), , drop = FALSE]) %>%
rename_with(~ paste0("macro_", .))
) %>%
# Añadir state_ord como covariable geográfica (no es factor latente)
left_join(state_covar %>% select(loan_id, state_ord, property_state),
by = "loan_id")
cat("  Dimensiones del espacio latente:", nrow(latent_space), "×", ncol(latent_space), "\n")
print(head(latent_space, 3))
# Exportar para clustering / deep learning
OUTPUT_DIR <- dirname(DATA_PATH)
write_csv(latent_space, file.path(OUTPUT_DIR, "latent_space_unified.csv"))
cat("\n✔ latent_space_unified.csv guardado en:", OUTPUT_DIR, "\n")
# =============================================================================
# VISUALIZACIONES RESUMEN
# =============================================================================
# 1. Heatmaps de matrices de correlación por bloque
pdf(file.path(OUTPUT_DIR, "correlation_heatmaps.pdf"), width = 12, height = 10)
par(mfrow = c(1, 3))
corrplot(b1_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B1: Originación", mar = c(0,0,2,0))
corrplot(b2_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B2: Comportamiento", mar = c(0,0,2,0))
corrplot(b3_cor$cor_mat, method = "color", tl.cex = 0.7,
title = "B3: Contextual", mar = c(0,0,2,0))
dev.off()
# 2. Diagramas de sendero AFC
pdf(file.path(OUTPUT_DIR, "path_diagrams_AFC.pdf"), width = 14, height = 10)
semPaths(b1_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 1 — Originación")
semPaths(b2_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 2 — Comportamiento")
semPaths(b3_afc$fit, what = "std", layout = "tree2",
title = TRUE, style = "lisrel",
edge.label.cex = 0.7, residuals = FALSE,
main = "AFC Bloque 3 — Contextual")
dev.off()
# 3. Distribución de factor scores del espacio latente
score_cols <- names(latent_space)[-1]
p_list <- lapply(score_cols, function(col) {
ggplot(latent_space, aes_string(x = col)) +
geom_histogram(bins = 30, fill = "#2E86C1", color = "white", alpha = 0.8) +
theme_minimal() +
labs(title = col, x = NULL, y = "n")
})
pdf(file.path(OUTPUT_DIR, "latent_score_distributions.pdf"),
width = 14, height = ceiling(length(score_cols) / 3) * 3)
do.call(grid.arrange, c(p_list, ncol = 3))
cat("B1 Originación\n")
print(b1_afc$indices)
cat("\nB2 Comportamiento\n")
print(b2_afc$indices)
cat("\nB3 Contextual\n")
print(b3_afc$indices)
